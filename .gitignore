# =========================================================================
# Core .NET & Visual Studio Ignores
# =========================================================================
bin/
obj/
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.vscode/
.idea/

# NuGet
packages/
*.nupkg

# Publish output
publish/
out/

# AppSettings (protect local dev settings & secrets)
appsettings.Development.json
secrets.json
.env
.env.*

# Logs & Temp files
*.log
*.tmp
*.temp

# Test results
TestResults/
coverage/
*.coverage
*.coveragexml

# OS generated files
Thumbs.db
Desktop.ini
.DS_Store

# =========================================================================
# Custom Ignores for Features 9, 10, 11, 12
# =========================================================================

# Feature 9: Reports
# Ignore any exported CSV or Excel reports generated by staff
/GeneratedReports/
*.csv
*.xlsx

# Feature 11: Email Invoices
# Ignore locally generated PDF invoices so they aren't pushed to Git
/Invoices/
/GeneratedInvoices/
*.pdf

# Feature 12: Registration & Uploads
# Ignore profile picture or document uploads if added in the future
/Uploads/ProfilePictures/
/Uploads/VehicleDocs/
